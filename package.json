{
  "name": "career-os",
  "version": "2.0.0",
  "description": "AI-powered career advancement operating system built on Claude Code: pipeline tracking, offer evaluation, CV generation, voice AI coaching, and a 12-tab web dashboard",
  "scripts": {
    "setup": "node setup.mjs",
    "start": "node dashboard-server.mjs",
    "dashboard": "node dashboard-web.mjs",
    "verify": "node verify-pipeline.mjs",
    "normalize": "node normalize-statuses.mjs",
    "dedup": "node dedup-tracker.mjs",
    "merge": "node merge-tracker.mjs",
    "pdf": "node generate-pdf.mjs",
    "sync-check": "node cv-sync-check.mjs",
    "test": "node --test __tests__/*.test.mjs",
    "test:unit": "node --test __tests__/dashboard-server.test.mjs __tests__/intelligence.test.mjs",
    "test:integration": "node --test __tests__/http-endpoints.test.mjs __tests__/lib-modules.test.mjs",
    "test:scripts": "node --test __tests__/merge-tracker.test.mjs __tests__/normalize-statuses.test.mjs __tests__/verify-pipeline.test.mjs"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "career",
    "automation",
    "career-os"
  ],
  "author": "Stephen C. Webster <stephen@futurespeak.ai> (https://futurespeak.ai)",
  "contributors": [
    "Santiago Fernandez de Valderrama <hi@santifer.io> (https://santifer.io)"
  ],
  "homepage": "https://github.com/FutureSpeakAI/career-os",
  "repository": {
    "type": "git",
    "url": "https://github.com/FutureSpeakAI/career-os"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "playwright": "^1.58.1",
    "ws": "^8.20.0"
  }
}
