# Career-OS API Keys
# Copy this file to .env and fill in your keys.
# Never commit .env to git -- it's in .gitignore.

# === Voice & Roleplay ===
# Gemini API key for voice interview roleplay (Gemini Live API)
GEMINI_API_KEY=

# ElevenLabs for high-quality text-to-speech (optional)
ELEVENLABS_API_KEY=

# === LLM Providers ===
# These are optional -- Career-OS works with Claude Code by default.
# Add these for multi-model evaluation diversity or batch processing.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=

# === Web Scraping ===
# Firecrawl for advanced JD extraction from complex pages
FIRECRAWL_API_KEY=

# === Design Assets ===
# Logo.Dev for fetching company logos in reports and presentations
LOGO_DEV_PUBLISHABLE_KEY=
LOGO_DEV_SECRET_KEY=

# === Other ===
# HuggingFace for open-source model access
HUGGINGFACE_TOKEN=

# === MCP Services (configured in Claude Code, not here) ===
# These are connected through Claude Code's MCP settings:
# - Gmail (inbox monitoring, draft responses)
# - Google Calendar (interview scheduling)
# - Box (document storage)
# - Canva (visual design)
# - Figma (diagrams, design context)
#
# To connect these, add the MCP servers in Claude Code settings.
# See docs/CONNECTIVITY.md for setup instructions.
